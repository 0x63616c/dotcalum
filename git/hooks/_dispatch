#!/usr/bin/env bash
# Centralized git-hook dispatcher (dotcalum) — installed via `git config --global core.hooksPath`.
#
# WHY ONE SCRIPT FOR EVERY HOOK
#   A global core.hooksPath REPLACES (does not merge with) a repo's own .git/hooks.
#   Git runs exactly ONE hooks directory. So we make every hook name in this dir a
#   symlink to THIS script, recover which hook fired from $0, run our global
#   handlers for it, then hand off to the repo's own hook of the same name — the
#   chaining git refuses to do for us.
#
# HOW TO EXTEND (the whole API)
#   Drop an executable into handlers.d/<hook>/NN-name.sh. Files run in sorted order.
#   Adding/removing a file is all there is — you never edit this script to extend it.
#   Each handler gets the hook's args ("$@"); its stdin is /dev/null (the real hook
#   stdin is reserved for the repo's own delegate, e.g. pre-push refs).
#
# TIMING
#   Every handler AND the repo-local delegate is timed; one JSONL line per step is
#   appended to the shared hooks log (see lib/hooklog.sh). Parse with jq.
#
# SAFE SEMANTICS (can't-mess-up)
#   * Gating hooks (pre-*, commit-msg, prepare-commit-msg, ...) fail-fast: the first
#     non-zero handler aborts and propagates its code, so a bad commit/push is still
#     blocked exactly like a normal hook.
#   * post-* hooks ignore failures (git ignores their exit anyway) and ALWAYS run
#     every handler and then the delegate.
#
# Repos that set their OWN core.hooksPath (lefthook, beads' .beads/hooks, husky)
# override this global one entirely and never reach here. That is correct — their
# tooling stays in charge. Those hooks are NOT timed by us (known gap; see CLAUDE.md).
set -uo pipefail

HOOK="$(basename "$0")"
HERE="$(cd "$(dirname "$0")" && pwd)"
HANDLER_DIR="$HERE/handlers.d/$HOOK"

# Shared timing/logging primitive. If missing, degrade to no-op so hooks still run.
# shellcheck source=/dev/null
. "$HERE/../../lib/hooklog.sh" 2>/dev/null || {
  hooklog_now_ms() { echo 0; }
  hooklog_step() { :; }
}

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || echo "")"
scope="$(basename "${repo_root:-$PWD}")"

# Hooks whose non-zero exit blocks the git operation.
case "$HOOK" in
  pre-commit|prepare-commit-msg|commit-msg|pre-merge-commit|pre-rebase|pre-push|\
  applypatch-msg|pre-applypatch|pre-auto-gc|push-to-checkout|sendemail-validate) gating=1 ;;
  *) gating=0 ;;
esac

t0="$(hooklog_now_ms)"
overall=0

# --- run global handlers for this hook ---------------------------------------
if [ -d "$HANDLER_DIR" ]; then
  for handler in "$HANDLER_DIR"/*; do
    [ -e "$handler" ] || continue   # empty-glob guard
    [ -x "$handler" ] || continue   # only executables
    s="$(hooklog_now_ms)"
    "$handler" "$@" </dev/null
    code=$?
    hooklog_step git "$scope" "$HOOK" "handler:$(basename "$handler")" "$(( $(hooklog_now_ms) - s ))" "$code"
    if [ "$code" -ne 0 ]; then
      overall="$code"
      if [ "$gating" -eq 1 ]; then
        hooklog_step git "$scope" "$HOOK" total "$(( $(hooklog_now_ms) - t0 ))" "$code"
        exit "$code"   # fail-fast: block the git op
      fi
    fi
  done
fi

# --- delegate to the repo's own hook of the same name, if present ------------
# `git rev-parse --git-path hooks` would return core.hooksPath (i.e. THIS dir), so
# we use --git-common-dir/hooks, which ignores core.hooksPath and is correct for
# linked worktrees too. We do NOT exec (we used to) — we run it as a child so it
# can be timed and logged, then exit with its code. Original stdin is passed
# through (pre-push/post-rewrite read refs from it). The -ef guard stops recursion.
common_dir="$(git rev-parse --git-common-dir 2>/dev/null || echo "")"
if [ -n "$common_dir" ]; then
  case "$common_dir" in /*) ;; *) common_dir="$PWD/$common_dir" ;; esac
  local_hook="$common_dir/hooks/$HOOK"
  if [ -x "$local_hook" ] && [ ! "$local_hook" -ef "$0" ]; then
    s="$(hooklog_now_ms)"
    "$local_hook" "$@"
    code=$?
    hooklog_step git "$scope" "$HOOK" "delegate:$HOOK" "$(( $(hooklog_now_ms) - s ))" "$code"
    hooklog_step git "$scope" "$HOOK" total "$(( $(hooklog_now_ms) - t0 ))" "$code"
    exit "$code"
  fi
fi

hooklog_step git "$scope" "$HOOK" total "$(( $(hooklog_now_ms) - t0 ))" "$overall"
exit "$overall"
